@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "Home Page";
}

<section class="bg-white dark:bg-gray-900">
    <div class="py-12 px-4 mx-auto max-w-screen-xl text-center lg:py-20">
        <h1 class="mb-4 text-4xl font-extrabold tracking-tight leading-none text-gray-900 md:text-5xl lg:text-6xl dark:text-white">
            Accreditation Portal
        </h1>
        <p class="mb-8 text-lg font-normal text-gray-500 lg:text-xl sm:px-16 lg:px-48 dark:text-gray-400">
            End-to-end digitization of the National Accreditation Council (NAC) institute and QAB accreditation
            workflow &mdash; from registration and self-assessment through desk review, on-site assessment, TA-QEC
            grading, and certificate issuance.
        </p>
        @if (SignInManager.IsSignedIn(User))
        {
            <p class="text-lg text-gray-700 dark:text-gray-300">
                Welcome back, <span class="font-semibold">@User.Identity!.Name</span>.
            </p>
        }
        else
        {
            <div class="flex flex-col mb-8 lg:mb-16 space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
                <a asp-controller="Account" asp-action="Register"
                   class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-white rounded-lg bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 dark:focus:ring-primary-900">
                    Register
                </a>
                <a asp-controller="Account" asp-action="Login"
                   class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-gray-900 rounded-lg border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 dark:text-white dark:border-gray-700 dark:hover:bg-gray-800 dark:focus:ring-gray-800">
                    Login
                </a>
            </div>
        }
    </div>
</section>
