@using accreditation_portal.Models.Applications
@using accreditation_portal.Models.DeskReviewViewModels
@model DeskReviewViewModel
@{
    ViewData["Title"] = "Desk Review";
    var application = Model.Application;
    var documentLabels = new Dictionary<ApplicationDocumentType, string>
    {
        [ApplicationDocumentType.RegistrationCertificate] = "Registration Certificate",
        [ApplicationDocumentType.AffiliationCertificate] = "Affiliation Certificate",
        [ApplicationDocumentType.FeeChallan] = "Fee Challan"
    };
}

<div class="max-w-4xl mx-auto space-y-6">
    @if (TempData["Error"] is string error)
    {
        <div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="p-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400">@success</div>
    }

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
                <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Application #@application.Id</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    @application.ApplicationType &middot; Reviewer: @(Model.ReviewerName ?? "-")
                    @if (Model.StartedAt.HasValue)
                    {
                        <text> &middot; Opened @Model.StartedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</text>
                    }
                </p>
            </div>
            @await Html.PartialAsync("_StatusBadge", Model.Status)
        </div>
    </div>

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-6">
        <div>
            <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-3">Account Details</h2>
            <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                @if (application.ApplicationType == ApplicationType.Institute)
                {
                    <div><dt class="text-gray-400 text-xs uppercase">Institute Name</dt><dd class="text-gray-900 dark:text-white">@(application.ApplicantUser.InstituteName ?? "-")</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">CNIC</dt><dd class="text-gray-900 dark:text-white">@(application.ApplicantUser.Cnic ?? "-")</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Mobile No.</dt><dd class="text-gray-900 dark:text-white">@(application.ApplicantUser.MobileNo ?? "-")</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Tehsil</dt><dd class="text-gray-900 dark:text-white">@(application.ApplicantUser.Tehsil ?? "-")</dd></div>
                }
                else
                {
                    <div><dt class="text-gray-400 text-xs uppercase">Full Name</dt><dd class="text-gray-900 dark:text-white">@application.ApplicantUser.FullName</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Email</dt><dd class="text-gray-900 dark:text-white">@(application.ApplicantUser.Email ?? "-")</dd></div>
                }
            </dl>
        </div>

        <hr class="border-gray-200 dark:border-gray-700" />

        <div>
            <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-3">Profile Details</h2>
            @if (application.ApplicationType == ApplicationType.Institute && application.InstituteProfile is { } instituteProfile)
            {
                <dl class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                    <div><dt class="text-gray-400 text-xs uppercase">Province</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.Province</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">District</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.District</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Address</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.Address</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Person</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.ContactPersonName</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Phone</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.ContactPhone</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Email</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.ContactEmail</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Registration Number</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.RegistrationNumber</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Affiliation Body</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.AffiliationBody</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Established Year</dt><dd class="text-gray-900 dark:text-white">@instituteProfile.EstablishedYear</dd></div>
                </dl>
            }
            else if (application.ApplicationType == ApplicationType.QAB && application.QABProfile is { } qabProfile)
            {
                <dl class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                    <div><dt class="text-gray-400 text-xs uppercase">Organization Name</dt><dd class="text-gray-900 dark:text-white">@qabProfile.OrganizationName</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Province</dt><dd class="text-gray-900 dark:text-white">@qabProfile.Province</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Address</dt><dd class="text-gray-900 dark:text-white">@qabProfile.Address</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Person</dt><dd class="text-gray-900 dark:text-white">@qabProfile.ContactPersonName</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Phone</dt><dd class="text-gray-900 dark:text-white">@qabProfile.ContactPhone</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Contact Email</dt><dd class="text-gray-900 dark:text-white">@qabProfile.ContactEmail</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Registration Number</dt><dd class="text-gray-900 dark:text-white">@qabProfile.RegistrationNumber</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Scope of Awarding</dt><dd class="text-gray-900 dark:text-white">@qabProfile.ScopeOfAwarding</dd></div>
                    <div><dt class="text-gray-400 text-xs uppercase">Accrediting Body Reference</dt><dd class="text-gray-900 dark:text-white">@(qabProfile.AccreditingBodyReference ?? "-")</dd></div>
                </dl>
            }
        </div>

        <hr class="border-gray-200 dark:border-gray-700" />

        <div>
            <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-3">Step 1 Documents</h2>
            <ul class="text-sm space-y-2">
                @foreach (var label in documentLabels)
                {
                    var doc = application.Documents.FirstOrDefault(d => d.DocumentType == label.Key);
                    <li class="flex items-center justify-between">
                        <span class="text-gray-700 dark:text-gray-300">@label.Value</span>
                        @if (doc is not null)
                        {
                            <a asp-controller="Applications" asp-action="Document" asp-route-documentId="@doc.Id" target="_blank" class="text-primary-600 dark:text-primary-500 hover:underline">@doc.FileName</a>
                        }
                        else
                        {
                            <span class="text-red-600">Missing</span>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">@Model.TemplateName</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Applicant's self-assessment, read-only. Add a note or flag a grey-area item below if needed.</p>
    </div>

    @foreach (var checklistSection in Model.Sections)
    {
        <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@checklistSection.Title</h2>

            @foreach (var item in checklistSection.Items)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 space-y-3 @(item.IsFlagged ? "ring-2 ring-amber-400" : "")">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-900 dark:text-white">@item.Title</p>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@item.Description</p>
                            }
                        </div>
                        <span class="shrink-0 text-sm font-semibold text-primary-700 dark:text-primary-400">
                            @(item.Score?.ToString() ?? "-") / @item.MaxScore
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.ApplicantComments))
                    {
                        <p class="text-xs text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-gray-700/40 rounded p-2">
                            <span class="font-medium">Applicant comment:</span> @item.ApplicantComments
                        </p>
                    }

                    @if (item.IsEvidenceRequired)
                    {
                        <div class="flex flex-wrap gap-2">
                            @if (item.Evidence.Any())
                            {
                                @foreach (var ev in item.Evidence)
                                {
                                    <a asp-controller="SelfAssessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank"
                                       class="text-xs text-primary-600 dark:text-primary-500 hover:underline bg-gray-50 dark:bg-gray-700/40 rounded px-2 py-1">
                                        @ev.FileName
                                    </a>
                                }
                            }
                            else
                            {
                                <span class="text-xs text-red-600">Evidence required - none attached</span>
                            }
                        </div>
                    }

                    @if (!Model.IsDecided)
                    {
                        <form asp-controller="DeskReview" asp-action="SaveItemNote" asp-route-id="@application.Id" method="post" class="pt-2 border-t border-gray-100 dark:border-gray-700 flex items-start gap-3">
                            <input type="hidden" name="ChecklistItemId" value="@item.ChecklistItemId" />
                            <label class="flex items-center gap-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 shrink-0 pt-2">
                                <input type="checkbox" name="IsFlagged" value="true" checked="@item.IsFlagged" class="rounded" />
                                Flag
                            </label>
                            <textarea name="Comment" rows="1" placeholder="Reviewer note (optional)"
                                      class="bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">@item.ReviewerComment</textarea>
                            <button type="submit" class="shrink-0 text-white bg-gray-700 hover:bg-gray-800 font-medium rounded-lg text-xs px-3 py-2 dark:bg-gray-600 dark:hover:bg-gray-500">
                                Save
                            </button>
                        </form>
                    }
                    else if (item.IsFlagged || !string.IsNullOrWhiteSpace(item.ReviewerComment))
                    {
                        <div class="pt-2 border-t border-gray-100 dark:border-gray-700 text-xs text-amber-700 dark:text-amber-400">
                            @if (item.IsFlagged)
                            {
                                <span class="font-semibold">Flagged.</span>
                            }
                            @item.ReviewerComment
                        </div>
                    }
                </div>
            }
        </div>
    }

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Desk Review Decision</h2>

        @if (Model.IsDecided)
        {
            <div class="flex items-center gap-3">
                @await Html.PartialAsync("_StatusBadge", Model.Status)
                <span class="text-xs text-gray-400">Decided @Model.DecidedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
            </div>
            <p class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-line">@Model.OverallComments</p>
        }
        else
        {
            <form asp-controller="DeskReview" asp-action="Decide" asp-route-id="@application.Id" method="post" class="space-y-3">
                <label class="block text-sm font-medium text-gray-900 dark:text-white">Overall Comments <span class="text-red-600">*</span></label>
                <textarea name="OverallComments" rows="4" required maxlength="4000"
                          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                          placeholder="Explain the basis for the decision - this will be visible to the applicant."></textarea>
                <div class="flex flex-wrap gap-3 pt-2">
                    <button type="submit" name="Decision" value="WorthyForVisit"
                            onclick="return confirm('Mark this application Worthy for Visit? This cannot be undone through the UI.');"
                            class="text-white bg-green-700 hover:bg-green-800 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800">
                        Worthy for Visit
                    </button>
                    <button type="submit" name="Decision" value="Deficient"
                            onclick="return confirm('Mark this application Deficient? This cannot be undone through the UI.');"
                            class="text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-800">
                        Deficient
                    </button>
                </div>
            </form>
        }

        <div class="pt-2">
            <a asp-controller="DeskReview" asp-action="Queue" class="text-sm font-medium text-primary-600 dark:text-primary-500 hover:underline">&larr; Back to Queue</a>
        </div>
    </div>
</div>
