@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    string CurrentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string CurrentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string NavClassFor(bool active) => active
        ? "flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary-50 text-primary-700 border-l-4 border-primary-600 font-semibold dark:bg-gray-700/60 dark:text-white dark:border-primary-500 group"
        : "flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 border-l-4 border-transparent hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-700/40 dark:hover:text-white group";
    string IconClassFor(bool active) => active
        ? "shrink-0 w-5 h-5 text-primary-600 dark:text-primary-400"
        : "shrink-0 w-5 h-5 text-gray-400 group-hover:text-gray-700 dark:text-gray-500 dark:group-hover:text-gray-300";
    string NavClass(string action) => NavClassFor(action == CurrentAction);
    string IconClass(string action) => IconClassFor(action == CurrentAction);
    var displayName = User.Identity?.Name ?? "";
    var initial = displayName.Length > 0 ? char.ToUpper(displayName[0]).ToString() : "?";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Accreditation Portal</title>
    <script type="importmap"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @@theme {
            --color-primary-50: #eff6ff;
            --color-primary-100: #dbeafe;
            --color-primary-200: #bfdbfe;
            --color-primary-300: #93c5fd;
            --color-primary-400: #60a5fa;
            --color-primary-500: #3b82f6;
            --color-primary-600: #2563eb;
            --color-primary-700: #1d4ed8;
            --color-primary-800: #1e40af;
            --color-primary-900: #1e3a8a;
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 dark:bg-gray-900">

    <aside id="admin-sidebar" class="fixed top-0 left-0 z-40 w-72 h-screen flex flex-col transition-transform -translate-x-full sm:translate-x-0 bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700" aria-label="Sidebar">

        <div class="flex items-center gap-3 px-5 h-20 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary-700 text-white dark:bg-primary-600">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l8 4-8 4-8-4 8-4z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 11v5c0 1.66 3.58 3 8 3s8-1.34 8-3v-5" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 9v6" />
                </svg>
            </div>
            <div class="leading-tight">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Accreditation Portal</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Admin Console</p>
            </div>
        </div>

        <div class="flex-1 px-4 py-5 overflow-y-auto">
            <p class="px-3 mb-2 text-xs font-semibold tracking-wider text-gray-400 uppercase dark:text-gray-500">Management</p>
            <ul class="space-y-1">
                <li>
                    <a asp-controller="Admin" asp-action="Users" class="@NavClass("Users")">
                        <svg class="@IconClass("Users")" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 18">
                            <path d="M14 2a3.963 3.963 0 0 0-1.4.267 6.439 6.439 0 0 1-1.331 6.638A4 4 0 1 0 14 2Zm1 9h-1.264A6.957 6.957 0 0 1 15 15v2a2.97 2.97 0 0 1-.184 1H19a1 1 0 0 0 1-1v-1a5.006 5.006 0 0 0-5-5ZM6.5 9a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9ZM8 10H5a5.006 5.006 0 0 0-5 5v2a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1v-2a5.006 5.006 0 0 0-5-5Z" />
                        </svg>
                        <span class="text-sm">User Management</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="CreateUser" class="@NavClass("CreateUser")">
                        <svg class="@IconClass("CreateUser") w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12h4m-2 2v-4M4 18v-1a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1Zm8-10a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>

                        <span class="text-sm">Create Internal User</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="Applications" class="@NavClass("Applications")">
                        <svg class="@IconClass("Applications")" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <span class="text-sm">All Applications</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="ChecklistTemplates" class="@NavClass("ChecklistTemplates")">
                        <svg class="@IconClass("ChecklistTemplates")" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                        </svg>
                        <span class="text-sm">Checklist Templates</span>
                    </a>
                </li>
                @{
                    var onDeskReviewQueue = CurrentController == "DeskReview" && (CurrentAction == "Queue" || CurrentAction == "Review");
                    var onDeskReviewReviewed = CurrentController == "DeskReview" && CurrentAction == "Reviewed";
                }
                <li>
                    <a asp-controller="DeskReview" asp-action="Queue" class="@NavClassFor(onDeskReviewQueue)">
                        <svg class="@IconClassFor(onDeskReviewQueue)" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-sm">Desk Review Queue</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="DeskReview" asp-action="Reviewed" class="@NavClassFor(onDeskReviewReviewed)">
                        <svg class="@IconClassFor(onDeskReviewReviewed)" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2a4 4 0 014-4h4m0 0l-3-3m3 3l-3 3M4 6h16M4 12h4m-4 6h7" />
                        </svg>
                        <span class="text-sm">Reviewed Applications</span>
                    </a>
                </li>
            </ul>

            <p class="px-3 mt-6 mb-2 text-xs font-semibold tracking-wider text-gray-400 uppercase dark:text-gray-500">General</p>
            <ul class="space-y-1">
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-600 border-l-4 border-transparent hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-700/40 dark:hover:text-white group">
                           <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4 12 8-8 8 8M6 10.5V19a1 1 0 0 0 1 1h3v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h3a1 1 0 0 0 1-1v-8.5" />
                        </svg>
                        <span class="text-sm">Back to Site</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="p-4 border-t border-gray-200 dark:border-gray-700">
            <div class="flex items-center gap-3 mb-3">
                <div class="flex items-center justify-center w-9 h-9 rounded-full bg-primary-100 text-primary-700 font-semibold text-sm dark:bg-primary-900 dark:text-primary-300">
                    @initial
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate dark:text-white">@displayName</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Administrator</p>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="flex items-center justify-center gap-2 w-full text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg px-4 py-2 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Logout
                </button>
            </form>
        </div>
    </aside>

    <button data-drawer-target="admin-sidebar" data-drawer-toggle="admin-sidebar" aria-controls="admin-sidebar" type="button" class="fixed top-4 left-4 z-50 inline-flex items-center p-2 text-sm text-gray-500 rounded-lg sm:hidden bg-white shadow hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600">
        <span class="sr-only">Open sidebar</span>
        <svg class="w-6 h-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
            <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z"></path>
        </svg>
    </button>

    <div class="sm:ml-72">
        <header class="sticky top-0 z-30 flex items-center h-20 px-6 sm:px-8 bg-white/80 backdrop-blur border-b border-gray-200 dark:bg-gray-900/80 dark:border-gray-700">
            <div class="ml-12 sm:ml-0">
                <p class="text-xs text-gray-400 dark:text-gray-500">Admin Console</p>
                <h1 class="text-lg font-semibold text-gray-900 dark:text-white">@ViewData["Title"]</h1>
            </div>
        </header>

        <main role="main" class="p-6 sm:p-8">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2/dist/flowbite.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
