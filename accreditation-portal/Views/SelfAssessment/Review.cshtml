@using accreditation_portal.Models.Applications
@using accreditation_portal.Models.SelfAssessmentViewModels
@model ChecklistViewModel?
@{
    ViewData["Title"] = "Review Self-Assessment";
}

<div class="max-w-4xl mx-auto space-y-6">
    @if (TempData["Error"] is string error)
    {
        <div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="p-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400">@success</div>
    }

    @if (Model is null)
    {
        <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 text-center">
            <p class="text-sm text-gray-500 dark:text-gray-400">@(ViewBag.Error ?? "No active self-assessment checklist is configured yet.")</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-8">
            <div class="flex items-center justify-between flex-wrap gap-3">
                <div>
                    <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">@Model.TemplateName</h1>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Application #@Model.ApplicationId &middot; @Model.CompletedItems of @Model.TotalItems items scored</p>
                </div>
                @await Html.PartialAsync("_StatusBadge", Model.Status)
            </div>

            @foreach (var checklistSection in Model.Sections)
            {
                <div>
                    <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-3">@checklistSection.Title</h2>
                    <div class="space-y-3">
                        @foreach (var item in checklistSection.Items)
                        {
                            <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                                <div class="flex items-start justify-between gap-4">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white">@item.Title</p>
                                    <span class="shrink-0 text-sm font-semibold text-primary-700 dark:text-primary-400">
                                        @(item.Score?.ToString() ?? "-") / @item.MaxScore
                                    </span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Comments))
                                {
                                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">@item.Comments</p>
                                }
                                @if (item.IsEvidenceRequired)
                                {
                                    <div class="mt-2 flex flex-wrap gap-2">
                                        @if (item.Evidence.Any())
                                        {
                                            @foreach (var ev in item.Evidence)
                                            {
                                                <a asp-controller="SelfAssessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank"
                                                   class="text-xs text-primary-600 dark:text-primary-500 hover:underline bg-gray-50 dark:bg-gray-700/40 rounded px-2 py-1">
                                                    @ev.FileName
                                                </a>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-xs text-red-600">Evidence required - none attached</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="flex items-center justify-between pt-2">
                @if (Model.Status == ApplicationStatus.SelfAssessmentInProgress)
                {
                    <a asp-controller="SelfAssessment" asp-action="Index" asp-route-id="@Model.ApplicationId" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline">&larr; Back to Checklist</a>
                    <form asp-controller="SelfAssessment" asp-action="Submit" asp-route-id="@Model.ApplicationId" method="post" onsubmit="return confirm('Submit your self-assessment? You will not be able to make further edits.');">
                        <button type="submit" class="text-white bg-green-700 hover:bg-green-800 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800">
                            Submit Self-Assessment
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Applications" asp-action="Index" class="text-sm font-medium text-primary-600 dark:text-primary-500 hover:underline">&larr; Back to My Applications</a>
                }
            </div>
        </div>
    }
</div>
