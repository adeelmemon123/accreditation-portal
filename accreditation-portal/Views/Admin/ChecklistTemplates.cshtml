@using accreditation_portal.Models.Applications
@model List<ChecklistTemplate>
@{
    ViewData["Title"] = "Checklist Templates";
}

<div class="mb-4 p-4 text-sm text-blue-800 rounded-lg bg-blue-50 dark:bg-gray-800 dark:text-blue-400">
    Read-only view of the seeded Self-Assessment checklist templates. A full template editor (create/edit/reorder
    sections and items) is a planned follow-up - for now templates are managed via <code>ChecklistTemplateSeeder</code>.
</div>

@if (!Model.Any())
{
    <p class="text-sm text-gray-500 dark:text-gray-400">No checklist templates have been seeded yet.</p>
}

@foreach (var template in Model)
{
    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 mb-6">
        <div class="flex items-center justify-between flex-wrap gap-3 mb-4">
            <div>
                <h2 class="text-lg font-bold text-gray-900 dark:text-white">@template.Name</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">@template.ApplicationType &middot; created @template.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(template.IsActive ? "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300" : "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300")">
                @(template.IsActive ? "Active" : "Inactive")
            </span>
        </div>

        @foreach (var checklistSection in template.Sections.OrderBy(s => s.DisplayOrder))
        {
            <div class="mb-4">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-2">@checklistSection.Title</h3>
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th scope="col" class="px-4 py-2">Item</th>
                            <th scope="col" class="px-4 py-2">Max Score</th>
                            <th scope="col" class="px-4 py-2">Evidence Required</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in checklistSection.Items.OrderBy(i => i.DisplayOrder))
                        {
                            <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                                <td class="px-4 py-2 text-gray-900 dark:text-white">@item.Title</td>
                                <td class="px-4 py-2">@item.MaxScore</td>
                                <td class="px-4 py-2">@(item.IsEvidenceRequired ? "Yes" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
