@model EditUserRolesViewModel
@{
    ViewData["Title"] = "Edit Roles";
    var hasTaqecRole = Model.Roles.Any(r => r.RoleName == Roles.TAQEC && r.IsSelected);
}

<h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Edit Roles</h1>
<p class="text-sm text-gray-500 dark:text-gray-400 mb-6">@Model.FullName (@Model.Email)</p>

<div class="w-full max-w-md bg-white rounded-lg shadow dark:border sm:p-6 dark:bg-gray-800 dark:border-gray-700">
    <form asp-controller="Admin" asp-action="EditRoles" method="post" class="space-y-3">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="FullName" />
        <input type="hidden" asp-for="Email" />

        @for (var i = 0; i < Model.Roles.Count; i++)
        {
            <div class="flex items-center">
                <input type="hidden" asp-for="@Model.Roles[i].RoleName" />
                <input asp-for="@Model.Roles[i].IsSelected" class="w-4 h-4 border border-gray-300 rounded-sm bg-gray-50 focus:ring-3 focus:ring-primary-300 dark:bg-gray-700 dark:border-gray-600 dark:focus:ring-primary-600" />
                <label class="ms-2 text-sm font-medium text-gray-900 dark:text-white">@Model.Roles[i].RoleName</label>
            </div>
        }

        @if (hasTaqecRole)
        {
            <div class="flex items-center pt-2 border-t border-gray-100 dark:border-gray-700 mt-2">
                <input asp-for="IsChairperson" class="w-4 h-4 border border-gray-300 rounded-sm bg-gray-50 focus:ring-3 focus:ring-primary-300 dark:bg-gray-700 dark:border-gray-600 dark:focus:ring-primary-600" />
                <label asp-for="IsChairperson" class="ms-2 text-sm font-medium text-gray-900 dark:text-white">TA-QEC Chairperson <span class="font-normal text-gray-400">(can lock the final grade)</span></label>
            </div>
        }

        <div class="flex items-center gap-3 pt-2">
            <button type="submit" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
                Save
            </button>
            <a asp-controller="Admin" asp-action="Users" class="text-sm font-medium text-primary-600 dark:text-primary-500 hover:underline">Back to list</a>
        </div>
    </form>
</div>
