@using accreditation_portal.Models.Applications
@using accreditation_portal.Models.AdminViewModels
@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    (string Label, string BarColor) StatusMeta(ApplicationStatus status) => status switch
    {
        ApplicationStatus.Draft => ("Draft", "bg-gray-400"),
        ApplicationStatus.Submitted => ("Submitted", "bg-blue-500"),
        ApplicationStatus.SelfAssessmentInProgress => ("Self-Assessment In Progress", "bg-indigo-500"),
        ApplicationStatus.SelfAssessmentSubmitted => ("Self-Assessment Submitted", "bg-teal-500"),
        ApplicationStatus.UnderDeskReview => ("Under Desk Review", "bg-yellow-500"),
        ApplicationStatus.WorthyForVisit => ("Worthy for Visit", "bg-purple-500"),
        ApplicationStatus.Deficient => ("Deficient", "bg-red-500"),
        ApplicationStatus.AssessmentAssigned => ("Assessment Assigned", "bg-cyan-500"),
        ApplicationStatus.AssessmentInProgress => ("Assessment In Progress", "bg-amber-500"),
        ApplicationStatus.AssessmentSubmitted => ("Assessment Submitted", "bg-emerald-500"),
        ApplicationStatus.UnderTaQecReview => ("Under TA-QEC Review", "bg-orange-500"),
        ApplicationStatus.TaQecGraded => ("TA-QEC Graded", "bg-lime-500"),
        _ => (status.ToString(), "bg-gray-400")
    };

    var maxStatusCount = Model.StatusCounts.Count > 0 ? Model.StatusCounts.Max(c => c.Count) : 0;
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Welcome back</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400">Here's where every application stands right now.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Total Applications</p>
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">@Model.TotalApplications</p>
            <p class="text-xs text-gray-400 mt-1">@Model.TotalInstitute Institute &middot; @Model.TotalQAB QAB</p>
        </div>

        <div class="bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Needs Your Action</p>
                <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
            </div>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">@Model.TotalPendingAction</p>
            <p class="text-xs text-gray-400 mt-1">Across Desk Review, Assessment &amp; TA-QEC queues</p>
        </div>

        <div class="bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Worthy for Visit</p>
                <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">@Model.WorthyForVisitCount</p>
            <p class="text-xs text-gray-400 mt-1">@Model.DeficientCount marked Deficient</p>
        </div>

        <div class="bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">TA-QEC Graded</p>
                <svg class="w-5 h-5 text-lime-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2a4 4 0 014-4h4m0 0l-3-3m3 3l-3 3M4 6h16M4 12h4m-4 6h7" /></svg>
            </div>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">@Model.GradedCount</p>
            <p class="text-xs text-gray-400 mt-1">Ready for the next module</p>
        </div>
    </div>

    <div>
        <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-3">Action Queues</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a asp-controller="DeskReview" asp-action="Queue" class="block bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5 hover:ring-2 hover:ring-primary-300 transition">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Desk Review</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.DeskReviewPendingCount <span class="text-sm font-normal text-gray-400">waiting</span></p>
                <p class="text-xs text-primary-600 dark:text-primary-500 mt-2">Go to queue &rarr;</p>
            </a>

            <a asp-controller="Assessment" asp-action="Queue" class="block bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5 hover:ring-2 hover:ring-primary-300 transition">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">On-Site Assessment</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.AssessmentNeedsTeamCount <span class="text-sm font-normal text-gray-400">need a team</span></p>
                @if (Model.AssessmentAwaitingAttentionCount > 0)
                {
                    <p class="text-xs font-semibold text-red-600 dark:text-red-400 mt-1">@Model.AssessmentAwaitingAttentionCount window(s) closed without submission</p>
                }
                <p class="text-xs text-primary-600 dark:text-primary-500 mt-2">Go to queue &rarr;</p>
            </a>

            <a asp-controller="TaQec" asp-action="Queue" class="block bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-5 hover:ring-2 hover:ring-primary-300 transition">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">TA-QEC Review</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.TaQecPendingCount <span class="text-sm font-normal text-gray-400">waiting</span></p>
                <p class="text-xs text-primary-600 dark:text-primary-500 mt-2">Go to queue &rarr;</p>
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow dark:border dark:bg-gray-800 dark:border-gray-700 p-6">
        <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-4">Applications by Status</h2>
        @if (!Model.StatusCounts.Any())
        {
            <p class="text-sm text-gray-500 dark:text-gray-400">No applications yet.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var statusCount in Model.StatusCounts.OrderByDescending(c => c.Count))
                {
                    var (label, barColor) = StatusMeta(statusCount.Status);
                    var widthPercent = maxStatusCount == 0 ? 0 : (statusCount.Count * 100 / maxStatusCount);
                    <div class="flex items-center gap-3">
                        <span class="w-48 shrink-0 text-xs font-medium text-gray-600 dark:text-gray-300 truncate">@label</span>
                        <div class="flex-1 h-3 rounded-full bg-gray-100 dark:bg-gray-700 overflow-hidden">
                            <div class="h-3 rounded-full @barColor" style="width: @(widthPercent)%"></div>
                        </div>
                        <span class="w-8 shrink-0 text-xs font-semibold text-gray-900 dark:text-white text-right">@statusCount.Count</span>
                    </div>
                }
            </div>
        }
    </div>
</div>
