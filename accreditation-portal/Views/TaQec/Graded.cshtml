@using accreditation_portal.Models.Applications
@model List<Application>
@{
    ViewData["Title"] = "Graded Applications";
    var selectedGrade = (TaQecGrade?)ViewBag.SelectedGrade;
}

<h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Graded Applications</h1>

<form method="get" class="flex flex-wrap items-end gap-4 mb-6">
    <div>
        <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Grade</label>
        <select name="grade" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
            <option value="">All</option>
            @foreach (var grade in new[] { TaQecGrade.A, TaQecGrade.B, TaQecGrade.C, TaQecGrade.D, TaQecGrade.NotRejected })
            {
                <option value="@grade" selected="@(selectedGrade == grade)">@grade</option>
            }
        </select>
    </div>
    <button type="submit" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
        Filter
    </button>
    <a asp-controller="TaQec" asp-action="Graded" class="text-sm font-medium text-primary-600 dark:text-primary-500 hover:underline">Clear</a>
</form>

<div class="relative overflow-x-auto shadow-md sm:rounded-lg">
    <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
        <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
                <th scope="col" class="px-6 py-3">Id</th>
                <th scope="col" class="px-6 py-3">Applicant</th>
                <th scope="col" class="px-6 py-3">Type</th>
                <th scope="col" class="px-6 py-3">Graded</th>
                <th scope="col" class="px-6 py-3">Grade</th>
                <th scope="col" class="px-6 py-3"><span class="sr-only">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var application in Model)
            {
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                    <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">#@application.Id</td>
                    <td class="px-6 py-4">@application.ApplicantUser.FullName</td>
                    <td class="px-6 py-4">@application.ApplicationType</td>
                    <td class="px-6 py-4">@application.TaQecReview?.LockedAt?.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td class="px-6 py-4 font-semibold">@application.TaQecReview?.Grade</td>
                    <td class="px-6 py-4 text-right">
                        <a asp-controller="TaQec" asp-action="Report" asp-route-applicationId="@application.Id" class="font-medium text-primary-600 dark:text-primary-500 hover:underline">View</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr class="bg-white dark:bg-gray-800">
                    <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">No graded applications match these filters.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
