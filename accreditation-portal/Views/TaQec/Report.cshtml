@using accreditation_portal.Models.Applications
@using accreditation_portal.Models.TaQecViewModels
@model TaQecReportViewModel
@{
    ViewData["Title"] = "TA-QEC Report";
    var isChairperson = (bool)ViewBag.IsChairperson;
}

<div class="max-w-4xl mx-auto space-y-6">
    @if (TempData["Error"] is string error)
    {
        <div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="p-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400">@success</div>
    }

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
                <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Application #@Model.Application.Id - @Model.ApplicantName</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">@Model.Application.ApplicationType &middot; Province: @(Model.Province ?? "-") &middot; Sector: @(Model.Sector ?? "-") &middot; @Model.TemplateName</p>
            </div>
            <div class="flex items-center gap-3">
                @await Html.PartialAsync("_StatusBadge", Model.Application.Status)
                <a asp-controller="TaQec" asp-action="DownloadPdf" asp-route-applicationId="@Model.Application.Id" target="_blank"
                   class="text-white bg-gray-700 hover:bg-gray-800 font-medium rounded-lg text-sm px-4 py-2 dark:bg-gray-600 dark:hover:bg-gray-500">
                    Download PDF
                </a>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4 mt-6 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/40">
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Avg Self-Score</p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">@(Model.AverageSelfScore?.ToString("0.0") ?? "-")</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Avg Assessor Score</p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">@(Model.AverageRecommendedScore?.ToString("0.0") ?? "-")</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Desk Review Flags</p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">@Model.FlaggedItemCount / @Model.TotalItemCount</p>
            </div>
        </div>
    </div>

    @foreach (var checklistSection in Model.Sections)
    {
        <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@checklistSection.Title</h2>

            @foreach (var item in checklistSection.Items)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 space-y-3 @(item.DeskReviewFlagged ? "ring-2 ring-amber-400" : "")">
                    <div class="flex items-start justify-between gap-4">
                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@item.Title</p>
                        @if (item.DeskReviewFlagged)
                        {
                            <span class="shrink-0 text-xs font-medium text-amber-700 dark:text-amber-400">Flagged by Desk Review</span>
                        }
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
                        <div class="bg-gray-50 dark:bg-gray-700/40 rounded p-3">
                            <p class="font-semibold text-gray-700 dark:text-gray-300 mb-1">Self-Assessment (Step 2)</p>
                            <p class="text-gray-900 dark:text-white font-medium mb-1">Score: @(item.SelfScore?.ToString() ?? "-") / @item.MaxScore</p>
                            @if (!string.IsNullOrWhiteSpace(item.SelfComments))
                            {
                                <p class="text-gray-600 dark:text-gray-300">@item.SelfComments</p>
                            }
                            @if (item.SelfEvidence.Any())
                            {
                                <div class="flex flex-wrap gap-1 mt-1">
                                    @foreach (var ev in item.SelfEvidence)
                                    {
                                        <a asp-controller="SelfAssessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank" class="text-primary-600 dark:text-primary-500 hover:underline">@ev.FileName</a>
                                    }
                                </div>
                            }
                        </div>

                        <div class="bg-gray-50 dark:bg-gray-700/40 rounded p-3">
                            <p class="font-semibold text-gray-700 dark:text-gray-300 mb-1">Desk Review (Step 3)</p>
                            @if (!string.IsNullOrWhiteSpace(item.DeskReviewComment))
                            {
                                <p class="text-gray-600 dark:text-gray-300">@item.DeskReviewComment</p>
                            }
                            else
                            {
                                <p class="text-gray-400">No note.</p>
                            }
                        </div>

                        <div class="bg-gray-50 dark:bg-gray-700/40 rounded p-3">
                            <p class="font-semibold text-gray-700 dark:text-gray-300 mb-1">On-Site Assessment (Step 4)</p>
                            <p class="text-gray-900 dark:text-white font-medium mb-1">Recommended: @(item.RecommendedScore?.ToString() ?? "-") / @item.MaxScore</p>
                            @if (!string.IsNullOrWhiteSpace(item.AssessorFindings))
                            {
                                <p class="text-gray-600 dark:text-gray-300"><span class="font-medium">Findings:</span> @item.AssessorFindings</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.AssessorStrengths))
                            {
                                <p class="text-gray-600 dark:text-gray-300"><span class="font-medium">Strengths:</span> @item.AssessorStrengths</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.AssessorWeaknesses))
                            {
                                <p class="text-gray-600 dark:text-gray-300"><span class="font-medium">Weaknesses:</span> @item.AssessorWeaknesses</p>
                            }
                            @if (item.AssessorEvidence.Any())
                            {
                                <div class="flex flex-wrap gap-1 mt-1">
                                    @foreach (var ev in item.AssessorEvidence)
                                    {
                                        <a asp-controller="Assessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank" class="text-primary-600 dark:text-primary-500 hover:underline">@ev.FileName</a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Committee Discussion</h2>

        @if (Model.DiscussionNotes.Any())
        {
            <ul class="space-y-3">
                @foreach (var note in Model.DiscussionNotes)
                {
                    <li class="border-l-4 border-primary-200 dark:border-primary-800 pl-3">
                        <p class="text-xs text-gray-400">
                            @note.AuthorName &middot; @note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            @if (note.ChecklistItemTitle is not null)
                            {
                                <text> &middot; on "@note.ChecklistItemTitle"</text>
                            }
                        </p>
                        <p class="text-sm text-gray-700 dark:text-gray-300">@note.Note</p>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-sm text-gray-500 dark:text-gray-400">No discussion notes yet.</p>
        }

        @if (!Model.IsLocked)
        {
            <form asp-controller="TaQec" asp-action="AddDiscussionNote" asp-route-applicationId="@Model.Application.Id" method="post" class="space-y-3 pt-2 border-t border-gray-100 dark:border-gray-700">
                <div>
                    <label class="block mb-1 text-xs font-medium text-gray-500 dark:text-gray-400">Optionally tag a checklist item</label>
                    <select name="ChecklistItemId" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                        <option value="">General remark</option>
                        @foreach (var checklistSection in Model.Sections)
                        {
                            @foreach (var item in checklistSection.Items)
                            {
                                <option value="@item.ChecklistItemId">@checklistSection.Title - @item.Title</option>
                            }
                        }
                    </select>
                </div>
                <textarea name="Note" rows="2" required maxlength="2000" placeholder="Add a discussion note..."
                          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"></textarea>
                <button type="submit" class="text-white bg-gray-700 hover:bg-gray-800 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-gray-600 dark:hover:bg-gray-500">
                    Add Note
                </button>
            </form>
        }
    </div>

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Grading Decision</h2>

        @if (Model.IsLocked)
        {
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-300">Grade: @Model.Grade</span>
                <span class="text-xs text-gray-400">Locked by @Model.LockedByName on @Model.LockedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
            </div>
            <p class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-line">@Model.RationaleRemarks</p>
        }
        else if (isChairperson)
        {
            <form asp-controller="TaQec" asp-action="LockGrade" asp-route-applicationId="@Model.Application.Id" method="post" class="space-y-3">
                <label class="block text-sm font-medium text-gray-900 dark:text-white">Final Grade <span class="text-red-600">*</span></label>
                <select name="Grade" required class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    <option value="">-- Select Grade --</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                    <option value="NotRejected">Not Rejected</option>
                </select>
                <label class="block text-sm font-medium text-gray-900 dark:text-white">Rationale/Remarks <span class="text-red-600">*</span></label>
                <textarea name="RationaleRemarks" rows="4" required maxlength="4000"
                          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                          placeholder="Justify the grading decision..."></textarea>
                <button type="submit"
                        onclick="return confirm('Lock this grade? This cannot be undone through the UI.');"
                        class="text-white bg-green-700 hover:bg-green-800 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800">
                    Lock Grade
                </button>
            </form>
        }
        else
        {
            <p class="text-sm text-gray-500 dark:text-gray-400">Only the TA-QEC Chairperson can lock the final grade.</p>
        }

        <div class="pt-2">
            <a asp-controller="TaQec" asp-action="Queue" class="text-sm font-medium text-primary-600 dark:text-primary-500 hover:underline">&larr; Back to Queue</a>
        </div>
    </div>
</div>
