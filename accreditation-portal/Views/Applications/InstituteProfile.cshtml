@using accreditation_portal.Models
@model InstituteProfileViewModel
@{
    ViewData["Title"] = "Institute Profile";
    var applicationId = (int)ViewBag.ApplicationId;
    var user = (ApplicationUser)ViewBag.ApplicantUser;
}

<div class="max-w-3xl mx-auto">
    @await Html.PartialAsync("_WizardSteps", 1)

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-8">
        <div>
            <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Institute Profile</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Details below are locked from your account. Complete the remaining fields for this application.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/40">
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Institute Name</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@(user.InstituteName ?? "-")</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">CNIC</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@(user.Cnic ?? "-")</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Mobile No.</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@(user.MobileNo ?? "-")</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Tehsil</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@(user.Tehsil ?? "-")</p>
            </div>
        </div>

        <form asp-controller="Applications" asp-action="InstituteProfile" asp-route-id="@applicationId" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Province" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Province <span class="text-red-600">*</span></label>
                    <input asp-for="Province" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="Province" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="District" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">District <span class="text-red-600">*</span></label>
                    <input asp-for="District" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="District" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="Address" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Address <span class="text-red-600">*</span></label>
                <input asp-for="Address" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                <span asp-validation-for="Address" class="text-red-600 text-sm"></span>
            </div>

            <hr class="border-gray-200 dark:border-gray-700" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="ContactPersonName" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Contact Person Name <span class="text-red-600">*</span></label>
                    <input asp-for="ContactPersonName" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="ContactPersonName" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="ContactPhone" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Contact Phone <span class="text-red-600">*</span></label>
                    <input asp-for="ContactPhone" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="ContactPhone" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="ContactEmail" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Contact Email <span class="text-red-600">*</span></label>
                    <input asp-for="ContactEmail" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="ContactEmail" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="RegistrationNumber" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Registration Number <span class="text-red-600">*</span></label>
                    <input asp-for="RegistrationNumber" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="RegistrationNumber" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="AffiliationBody" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Affiliation Body <span class="text-red-600">*</span></label>
                    <input asp-for="AffiliationBody" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="AffiliationBody" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="EstablishedYear" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Established Year <span class="text-red-600">*</span></label>
                    <input asp-for="EstablishedYear" type="number" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                    <span asp-validation-for="EstablishedYear" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="Sector" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">Sector <span class="text-red-600">*</span> <span class="font-normal text-gray-400">(e.g. IT, Construction, Textile)</span></label>
                <input asp-for="Sector" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Used to match on-site assessors during the assessment stage.</p>
                <span asp-validation-for="Sector" class="text-red-600 text-sm"></span>
            </div>

            <div class="flex justify-end">
                <button type="submit" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
                    Save &amp; Continue to Documents
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
