@using accreditation_portal.Models.Applications
@model List<Application>
@{
    ViewData["Title"] = "My Applications";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Applications</h1>
    @if (!Model.Any(a => a.Status == ApplicationStatus.Draft))
    {
        <a asp-controller="Applications" asp-action="Start"
           class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
            Start Application
        </a>
    }
</div>

@if (TempData["Error"] is string error)
{
    <div class="mb-4 p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">@error</div>
}

@if (!Model.Any())
{
    <div class="text-center bg-white rounded-lg shadow dark:bg-gray-800 dark:border dark:border-gray-700 p-12">
        <p class="text-gray-500 dark:text-gray-400 mb-4">You haven't started an application yet.</p>
        <a asp-controller="Applications" asp-action="Start" class="font-medium text-primary-600 dark:text-primary-500 hover:underline">Start your application</a>
    </div>
}
else
{
    <div class="relative overflow-x-auto shadow-md sm:rounded-lg">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                    <th scope="col" class="px-6 py-3">Application Id</th>
                    <th scope="col" class="px-6 py-3">Type</th>
                    <th scope="col" class="px-6 py-3">Status</th>
                    <th scope="col" class="px-6 py-3">Started</th>
                    <th scope="col" class="px-6 py-3">Submitted</th>
                    <th scope="col" class="px-6 py-3"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var application in Model)
                {
                    <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                        <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">#@application.Id</td>
                        <td class="px-6 py-4">@application.ApplicationType</td>
                        <td class="px-6 py-4">@await Html.PartialAsync("_StatusBadge", application.Status)</td>
                        <td class="px-6 py-4">@application.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td class="px-6 py-4">@(application.SubmittedAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "-")</td>
                        <td class="px-6 py-4 text-right">
                            @if (application.Status == ApplicationStatus.Draft)
                            {
                                <a asp-controller="Applications" asp-action="Profile" asp-route-id="@application.Id" class="font-medium text-primary-600 dark:text-primary-500 hover:underline">Continue</a>
                            }
                            else
                            {
                                <a asp-controller="Applications" asp-action="Review" asp-route-id="@application.Id" class="font-medium text-primary-600 dark:text-primary-500 hover:underline">View</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
