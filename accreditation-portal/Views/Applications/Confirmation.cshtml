@model Application
@{
    ViewData["Title"] = "Application Submitted";
}

<div class="flex justify-center">
    <div class="w-full max-w-xl bg-white rounded-lg shadow dark:border sm:p-10 p-6 dark:bg-gray-800 dark:border-gray-700 text-center">
        <div class="mx-auto flex items-center justify-center w-16 h-16 rounded-full bg-green-50 dark:bg-gray-700 mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Application Submitted</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
            Your @Model.ApplicationType application has been submitted for review. You'll be notified as it
            progresses through the review process.
        </p>

        <div class="grid grid-cols-2 gap-4 p-4 rounded-lg bg-gray-50 dark:bg-gray-700/40 mb-6 text-left">
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Application Id</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">#@Model.Id</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Status</p>
                @await Html.PartialAsync("_StatusBadge", Model.Status)
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide">Submitted On</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@Model.SubmittedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
            </div>
        </div>

        <a asp-controller="Applications" asp-action="Index" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
            Go to My Applications
        </a>
    </div>
</div>
