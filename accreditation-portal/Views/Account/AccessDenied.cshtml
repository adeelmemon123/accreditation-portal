@{
    ViewData["Title"] = "Access Denied";
    // Shown to already-logged-in users lacking a permission - keep the normal navbar for navigation,
    // unlike the pre-login Account views (Login/Register*) which use the navbar-free _AuthLayout.
    Layout = "_Layout";
}

<h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Access Denied</h1>
<p class="text-gray-700 dark:text-gray-300">You do not have permission to access this resource.</p>
