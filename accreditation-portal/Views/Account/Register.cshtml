@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="flex justify-center">
    <div class="w-full bg-white rounded-lg shadow dark:border sm:max-w-2xl xl:p-0 dark:bg-gray-800 dark:border-gray-700">
        <div class="p-6 sm:p-10 space-y-8">

            <div class="text-center space-y-2">
                <div class="mx-auto flex items-center justify-center w-16 h-16 rounded-full bg-primary-50 dark:bg-gray-700">
                    <svg class="w-8 h-8 text-primary-700 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l8 4-8 4-8-4 8-4z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 11v5c0 1.66 3.58 3 8 3s8-1.34 8-3v-5" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 9v6" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold leading-tight tracking-tight text-gray-900 md:text-3xl dark:text-white">
                    Institute / QAB Signup
                </h1>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login" class="font-medium text-primary-600 hover:underline dark:text-primary-500">Sign in</a>
                </p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post" class="space-y-8">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="AccountType" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Account Type <span class="text-red-600">*</span>
                        </label>
                        <select asp-for="AccountType" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500">
                            <option value="@Roles.Institute">Institute</option>
                            <option value="@Roles.QAB">Qualification Awarding Body (QAB)</option>
                        </select>
                        <span asp-validation-for="AccountType" class="text-red-600 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="Province" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Province
                        </label>
                        <input asp-for="Province" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                        <span asp-validation-for="Province" class="text-red-600 text-sm"></span>
                    </div>
                </div>

                <hr class="border-gray-200 dark:border-gray-700" />

                <div>
                    <h2 class="text-base font-semibold text-gray-900 dark:text-white">Focal Person Details</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Please provide the information of the focal person for this account.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="FullName" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Full Name <span class="font-normal text-gray-400">(As per CNIC)</span> <span class="text-red-600">*</span>
                        </label>
                        <input asp-for="FullName" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                        <span asp-validation-for="FullName" class="text-red-600 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Email <span class="text-red-600">*</span>
                        </label>
                        <input asp-for="Email" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                        <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Please provide a valid email address for important notifications and correspondence.</p>
                        <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                    </div>
                </div>

                <hr class="border-gray-200 dark:border-gray-700" />

                <div>
                    <h2 class="text-base font-semibold text-gray-900 dark:text-white">Account Security</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Choose a strong password to protect your account.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Password" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Password <span class="text-red-600">*</span>
                        </label>
                        <input asp-for="Password" type="password" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                        <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="ConfirmPassword" class="block mb-2 text-sm font-semibold text-gray-900 dark:text-white">
                            Confirm Password <span class="text-red-600">*</span>
                        </label>
                        <input asp-for="ConfirmPassword" type="password" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm"></span>
                    </div>
                </div>

                <button type="submit" class="w-full text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-3 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
                    Register
                </button>

                <p class="text-xs text-center text-gray-400 dark:text-gray-500">
                    Self-registration is for Institutes and Qualification Awarding Bodies (QABs) only. Other roles are provisioned by the Accreditation Wing administrator.
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
