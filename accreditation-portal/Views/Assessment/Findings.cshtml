@using accreditation_portal.Models.Applications
@using accreditation_portal.Models.AssessmentViewModels
@model FindingsViewModel
@{
    ViewData["Title"] = "On-Site Assessment Findings";
    var isTeamMember = (bool)ViewBag.IsTeamMember;
    var isConvener = (bool)ViewBag.IsConvener;
    var canEdit = isTeamMember && Model.IsWindowLive;
    var canSubmit = (isTeamMember || isConvener) && Model.IsWindowLive && Model.AssignmentStatus != AssessmentAssignmentStatus.FindingsSubmitted;
    var globalIndex = 0;
}

<div class="max-w-4xl mx-auto space-y-6">
    @if (TempData["Error"] is string error)
    {
        <div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="p-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400">@success</div>
    }

    <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
                <h1 class="text-xl font-bold text-gray-900 dark:text-white mb-1">Application #@Model.Application.Id</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">@Model.Application.ApplicantUser.FullName &middot; @Model.Application.ApplicationType &middot; @Model.TemplateName</p>
            </div>
            <div class="text-right">
                @if (Model.AssignmentStatus == AssessmentAssignmentStatus.FindingsSubmitted)
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 dark:bg-teal-900 dark:text-teal-300">Findings Submitted</span>
                }
                else if (Model.IsWindowLive && Model.WindowEndAt.HasValue)
                {
                    var remaining = Model.WindowEndAt.Value - DateTime.UtcNow;
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300">
                        @((int)remaining.TotalDays)d @remaining.Hours h remaining (closes @Model.WindowEndAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm"))
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">Window Closed</span>
                }
            </div>
        </div>
    </div>

    @if (!canEdit && Model.AssignmentStatus != AssessmentAssignmentStatus.FindingsSubmitted)
    {
        <div class="p-4 text-sm text-amber-800 rounded-lg bg-amber-50 dark:bg-gray-800 dark:text-amber-400">
            @(isTeamMember ? "The assessment window is closed - findings are now read-only." : "You have read-only access to these findings.")
        </div>
    }

    @if (canEdit)
    {
        <form id="findingsForm" asp-controller="Assessment" asp-action="SaveFindings" asp-route-assignmentId="@Model.AssignmentId" method="post" enctype="multipart/form-data" class="space-y-6"></form>
    }

    @foreach (var checklistSection in Model.Sections)
    {
        <div class="bg-white rounded-lg shadow dark:border sm:p-8 p-6 dark:bg-gray-800 dark:border-gray-700 space-y-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">@checklistSection.Title</h2>

            @foreach (var item in checklistSection.Items)
            {
                var idx = globalIndex;
                globalIndex++;

                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 space-y-3">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-900 dark:text-white">@item.Title</p>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@item.Description</p>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.LastUpdatedByName))
                        {
                            <p class="text-xs text-gray-400 shrink-0">Last updated by @item.LastUpdatedByName<br />@item.LastUpdatedAt?.ToLocalTime().ToString("dd MMM HH:mm")</p>
                        }
                    </div>

                    @if (canEdit)
                    {
                        <input type="hidden" form="findingsForm" name="Items[@idx].ChecklistItemId" value="@item.ChecklistItemId" />

                        <div>
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Recommended score (0&ndash;@item.MaxScore)</p>
                            <div class="flex flex-wrap gap-2">
                                @for (var score = 0; score <= item.MaxScore; score++)
                                {
                                    var inputId = $"score-{item.ChecklistItemId}-{score}";
                                    <label for="@inputId" class="cursor-pointer">
                                        <input type="radio" id="@inputId" form="findingsForm" name="Items[@idx].RecommendedScore" value="@score"
                                               class="sr-only peer" checked="@(item.RecommendedScore == score)" />
                                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg border text-sm font-medium border-gray-300 text-gray-700 dark:border-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 peer-checked:bg-primary-600 peer-checked:text-white peer-checked:border-primary-600">
                                            @score
                                        </span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Strengths</label>
                                <textarea form="findingsForm" name="Items[@idx].Strengths" rows="2" maxlength="2000"
                                          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">@item.Strengths</textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Weaknesses</label>
                                <textarea form="findingsForm" name="Items[@idx].Weaknesses" rows="2" maxlength="2000"
                                          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">@item.Weaknesses</textarea>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">Findings <span class="text-red-600">*</span></label>
                            <textarea form="findingsForm" name="Items[@idx].Findings" rows="2" maxlength="2000"
                                      class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">@item.Findings</textarea>
                        </div>

                        <div class="pt-2 border-t border-gray-100 dark:border-gray-700">
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-2">Evidence (optional)</p>
                            @if (item.Evidence.Any())
                            {
                                <ul class="space-y-1 mb-2">
                                    @foreach (var ev in item.Evidence)
                                    {
                                        <li class="flex items-center justify-between text-sm bg-gray-50 dark:bg-gray-700/40 rounded px-3 py-1.5">
                                            <a asp-controller="Assessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank" class="text-primary-600 dark:text-primary-500 hover:underline truncate">@ev.FileName</a>
                                            <span class="text-xs text-gray-400 mx-2 shrink-0">@((ev.FileSizeBytes / 1024.0).ToString("N0")) KB</span>
                                            <button type="submit" form="delete-evidence-@ev.Id" onclick="return confirm('Remove this evidence file?');" class="text-xs font-medium text-red-600 hover:underline shrink-0">Remove</button>
                                        </li>
                                    }
                                </ul>
                            }
                            <input type="file" form="findingsForm" name="Items[@idx].EvidenceFile" accept=".pdf,.jpg,.jpeg,.png"
                                   class="block w-full text-xs text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 dark:text-gray-400 focus:outline-none dark:bg-gray-700 dark:border-gray-600" />
                        </div>
                    }
                    else
                    {
                        <dl class="grid grid-cols-2 gap-3 text-sm">
                            <div><dt class="text-gray-400 text-xs uppercase">Recommended Score</dt><dd class="text-gray-900 dark:text-white">@(item.RecommendedScore?.ToString() ?? "-") / @item.MaxScore</dd></div>
                        </dl>
                        @if (!string.IsNullOrWhiteSpace(item.Strengths))
                        {
                            <p class="text-xs text-gray-600 dark:text-gray-300"><span class="font-medium">Strengths:</span> @item.Strengths</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Weaknesses))
                        {
                            <p class="text-xs text-gray-600 dark:text-gray-300"><span class="font-medium">Weaknesses:</span> @item.Weaknesses</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Findings))
                        {
                            <p class="text-xs text-gray-600 dark:text-gray-300"><span class="font-medium">Findings:</span> @item.Findings</p>
                        }
                        @if (item.Evidence.Any())
                        {
                            <div class="flex flex-wrap gap-2 pt-2">
                                @foreach (var ev in item.Evidence)
                                {
                                    <a asp-controller="Assessment" asp-action="Evidence" asp-route-evidenceId="@ev.Id" target="_blank"
                                       class="text-xs text-primary-600 dark:text-primary-500 hover:underline bg-gray-50 dark:bg-gray-700/40 rounded px-2 py-1">@ev.FileName</a>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }

    <div class="flex items-center justify-between bg-white rounded-lg shadow dark:border sm:p-6 p-4 dark:bg-gray-800 dark:border-gray-700">
        <a asp-controller="Assessment" asp-action="MyAssignments" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline">&larr; Back to My Assignments</a>
        <div class="flex items-center gap-3">
            @if (canEdit)
            {
                <button type="submit" form="findingsForm" class="text-white bg-gray-700 hover:bg-gray-800 focus:ring-4 focus:outline-none focus:ring-gray-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-gray-600 dark:hover:bg-gray-500">
                    Save Progress
                </button>
            }
            @if (canSubmit)
            {
                <form asp-controller="Assessment" asp-action="Submit" asp-route-assignmentId="@Model.AssignmentId" method="post" onsubmit="return confirm('Submit these findings? You will not be able to make further edits.');">
                    <button type="submit" class="text-white bg-green-700 hover:bg-green-800 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm px-6 py-2.5 text-center dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800">
                        Submit Findings
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@if (canEdit)
{
    @foreach (var checklistSection in Model.Sections)
    {
        @foreach (var item in checklistSection.Items)
        {
            @foreach (var ev in item.Evidence)
            {
                <form id="delete-evidence-@ev.Id" asp-controller="Assessment" asp-action="DeleteEvidence" asp-route-assignmentId="@Model.AssignmentId" method="post" class="hidden">
                    <input type="hidden" name="evidenceId" value="@ev.Id" />
                </form>
            }
        }
    }
}
